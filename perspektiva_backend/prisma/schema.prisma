generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model UserInterest {
  userId     String
  interestId Int
  interest   interest @relation(fields: [interestId], references: [id])
  user       user     @relation(fields: [userId], references: [id])

  @@id([userId, interestId])
  @@index([interestId], map: "users_interests_interestId_fkey")
  @@map("users_interests")
}

model ArticleInterest {
  articleId  Int
  interestId Int
  article    article  @relation(fields: [articleId], references: [id])
  interest   interest @relation(fields: [interestId], references: [id])

  @@id([articleId, interestId])
  @@index([interestId], map: "articles_interests_interestId_fkey")
  @@map("articles_interests")
}

model article {
  id          Int               @id @default(autoincrement())
  title       String
  publicistId Int
  content     String            @db.LongText
  publicist   publicist         @relation(fields: [publicistId], references: [id], map: "Article_publicistId_fkey")
  interests   ArticleInterest[]
  favourites  favourites[]

  @@index([publicistId], map: "Article_publicistId_fkey")
}

model interest {
  id       Int               @id @default(autoincrement())
  name     String
  articles ArticleInterest[]
  users    UserInterest[]
}

model publicist {
  id      Int       @id @default(autoincrement())
  name    String
  user_id String?
  article article[]
  user    user?     @relation(fields: [user_id], references: [id], onUpdate: SetNull, map: "publicist_ibfk_1")

  @@index([user_id], map: "user_id")
}

model user {
  id         String         @id @default(uuid())
  email      String         @unique(map: "User_email_key")
  password   String
  name       String?
  isAdmin    Boolean        @default(false)
  favourites favourites[]
  publicist  publicist[]
  interests  UserInterest[]
  mediums mediums[]
}

model favourites {
  id         Int      @id @default(autoincrement())
  user_id    String?
  article_id Int?
  article    article? @relation(fields: [article_id], references: [id], onUpdate: SetNull)
  user       user?    @relation(fields: [user_id], references: [id], onUpdate: SetNull)

  @@unique([user_id, article_id])
  @@index([article_id], map: "favourites_article_id_fkey")
}

model mediums {
  id      Int     @id @default(autoincrement())
  name    String
  active  Boolean
  user_id String

  user user @relation(fields: [user_id], references: [id])
  @@index([user_id], map: "user_id")
}
